# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="Lara App"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000
APP_TIMEZONE=UTC
APP_KEY=change-me-in-production
APP_ADDR=0.0.0.0:3000

# Logging (env_logger / tracing filter)
RUST_LOG=info,example=debug

# ─────────────────────────────────────────────────────────────────────────────
# Database
#   Option A — a single connection URL; the driver is inferred from the scheme:
#     postgres://user:pass@host:5432/db   mysql://user:pass@host:3306/db
#     mongodb://host:27017/db             sqlite://database/app.db
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://postgres:secret@localhost:5432/lara

#   Option B — discrete vars. DB_CONNECTION selects the driver:
#     sqlite (default) | postgres | mysql | mongodb
DB_CONNECTION=sqlite

# SQLite
DB_PATH=database/app.db

# Postgres / MySQL
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=lara
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSL=false

# Pool tuning (all drivers)
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_CONNECT_TIMEOUT=30

# ── MongoDB ──────────────────────────────────────────────────────────────────
# MONGO_URI / DB_URI takes precedence over DB_HOST/DB_PORT when set.
# DB_URI=mongodb://localhost:27017
# Authentication (optional — uses DB_USERNAME / DB_PASSWORD):
# MONGO_AUTH_SOURCE=admin
# Replica set name — REQUIRED for multi-document transactions (Db::mongo_transaction):
# MONGO_REPLICA_SET=rs0
# Topology: "true" = direct/standalone connection, "false" = replica-set discovery (auto if unset)
# MONGO_DIRECT_CONNECTION=false
# Retry writes: "true" for replica sets, "false" for standalone
# MONGO_RETRY_WRITES=true
# Server selection timeout (ms)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-me
JWT_TTL=24            # access token lifetime (hours)
JWT_REFRESH_TTL=168   # refresh token lifetime (hours)
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# Cache
#   driver: memory (default) | file | redis
# ─────────────────────────────────────────────────────────────────────────────
CACHE_DRIVER=memory
CACHE_PREFIX=lara_
CACHE_PATH=storage/cache
REDIS_URL=redis://127.0.0.1:6379

# ─────────────────────────────────────────────────────────────────────────────
# Queue
#   driver: sync (default) | database | redis
# ─────────────────────────────────────────────────────────────────────────────
QUEUE_DRIVER=sync
QUEUE_NAME=default

# ─────────────────────────────────────────────────────────────────────────────
# Mail
#   driver: log (default) | smtp | mailgun | sendgrid | null
# ─────────────────────────────────────────────────────────────────────────────
MAIL_DRIVER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Lara App"

# SMTP
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=none   # none | tls | starttls

# Mailgun / SendGrid
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# SENDGRID_API_KEY=
